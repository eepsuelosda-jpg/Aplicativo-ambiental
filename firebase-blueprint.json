{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and role information",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "name": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "inspector"] },
        "permissions": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["email", "role"]
    },
    "Inspection": {
      "title": "Inspection",
      "description": "Technical inspection record for EEP",
      "type": "object",
      "properties": {
        "inspectorId": { "type": "string" },
        "inspectorName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "generalData": {
          "type": "object",
          "properties": {
            "component": { "type": "string" },
            "address": { "type": "string" },
            "locality": { "type": "string" },
            "neighborhood": { "type": "string" },
            "entryRadicado": { "type": "string" },
            "process": { "type": "string" },
            "visitDate": { "type": "string" },
            "startTime": { "type": "string" },
            "authority": { "type": "string" },
            "fileNo": { "type": "string" }
          }
        },
        "reason": { "type": "string" },
        "situations": { "type": "object" },
        "finalConsiderations": { "type": "string" },
        "location": {
          "type": "object",
          "properties": {
            "lat": { "type": "number" },
            "lng": { "type": "number" }
          }
        }
      },
      "required": ["inspectorId", "createdAt", "generalData"]
    },
    "Zone": {
      "title": "Zone",
      "description": "Marked zones on the map",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "locality": { "type": "string" },
        "type": { "type": "string", "enum": ["point", "area"] },
        "coordinates": { "type": "array" }
      },
      "required": ["name", "locality", "coordinates"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/inspections/{inspectionId}": {
      "schema": "Inspection",
      "description": "Inspection records"
    },
    "/zones/{zoneId}": {
      "schema": "Zone",
      "description": "Map zones and markings"
    }
  }
}
